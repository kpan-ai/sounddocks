{
  "name": "sounddocks",
  "version": "1.0.0",
  "description": "A clean soundboard app for Discord via VB-Cable",
  "main": "main.js",
  "author": "Resona",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "dist-mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.sounddocks.app",
    "productName": "Sounddocks",
    "publish": {
      "provider": "github",
      "owner": "kpan-ai",
      "repo": "sounddocks",
      "releaseType": "release"
},
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.music"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Sounddocks"
    },
    "files": [
      "main.js",
      "index.html",
      "app.js",
      "style.css",
      "assets/**",
      "sounds/**"
    ]
  }
}
